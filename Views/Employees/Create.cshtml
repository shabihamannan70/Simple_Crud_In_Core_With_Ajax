@model Employee
@{
    ViewData["Title"] = "Create";
}
<h2 class="display-4">Create</h2>
<div class="row">
    <div class="col">
        <div id="panel"></div>
        <form id="frmCreate"
            asp-action="Create"
            asp-controller="Employees"
            data-ajax-method="Post"
            data-ajax="true"
            data-ajax-mode="replace"
            data-ajax-update="#panel"
            data-ajax-success="success">

            <div class="row">
                <label asp-for="EmployeeName" class="col-form-label col-3">Name</label>
                <div class="col-8">
                    <input/>

                </div>
            </div>

        </form>
    </div>
</div>

@section Scripts{
    <script>
        function success(){
            $("#frmCreate").trigger('reset');
        }
    </script>
}